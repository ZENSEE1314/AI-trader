# Copy this to .env for local testing
# Add these as Environment Variables in Render dashboard

# ── Telegram ──
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Bitunix API (for owner account) ──
BITUNIX_API_KEY=your_bitunix_api_key_here
BITUNIX_API_SECRET=your_bitunix_api_secret_here

# ── QuotaGuard Static IP Proxy ──
# HTTP proxy (recommended for Render):
# PROXY_URL=http://qxl2t0zsxx7qno:n42glgkmny99p49hez2n9zn4f4bkd0@ap-northeast-static-01.quotaguard.com:9293
# SOCKS5 proxy (if supported):
# PROXY_URL=socks5://qxl2t0zsxx7qno:n42glgkmny99p49hez2n9zn4f4bkd0@ap-northeast-static-01.quotaguard.com:1080
PROXY_URL=http://your_quotaguard_proxy_url_here

# ── Binance API (legacy/optional) ──
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
